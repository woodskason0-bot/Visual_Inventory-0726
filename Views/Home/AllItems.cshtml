@model IEnumerable<Visual_Inventory_System.Models.InventoryItem>
@{
    ViewData["Title"] = "All Items";
    Func<string, bool> needsPn = pn => string.IsNullOrWhiteSpace(pn) || pn.Trim().Equals("N/A", StringComparison.OrdinalIgnoreCase);
}

<style>
    .allitems-wrap { max-width: 1300px; margin: 1.5rem auto; }

    .allitems-card {
        background-color: var(--vis-card);
        border: 1px solid var(--vis-card-border);
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.45);
    }

    .allitems-card table { color: var(--vis-text); margin-bottom: 0; }
    .allitems-card thead th {
        background-color: #14151A;
        color: #CBD5E1;
        border-color: var(--vis-card-border) !important;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.4px;
    }
    .allitems-card tbody td {
        border-color: var(--vis-card-border) !important;
        vertical-align: middle;
    }
    .allitems-card tbody tr:nth-of-type(odd) { background-color: rgba(255,255,255,0.02); }
    .allitems-card tbody tr:hover { background-color: rgba(216,43,51,0.07); }
    .allitems-card .text-dim { color: #94A3B8 !important; }
</style>

<div class="allitems-wrap px-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-white">
            <i class="bi bi-box-seam me-2" style="color: var(--vis-red);"></i>All Items in Inventory (@Model.Count())
        </h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    <div class="allitems-card p-4">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Rheem PN</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Brand</th>
                    <th>Team</th>
                    <th>Qty</th>
                    <th>Location</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ItemId</td>
                        <td>
                            @if (needsPn(item.RheemPartNumber))
                            {
                                <span class="badge bg-warning text-dark fw-bold">No Rheem PN</span>
                            }
                            else
                            {
                                @item.RheemPartNumber
                            }
                        </td>
                        <td>@item.ItemName</td>
                        <td class="text-dim">@item.Type</td>
                        <td class="text-dim">@item.Brand</td>
                        <td class="text-dim">@item.Team</td>
                        <td class="fw-bold @(item.Quantity == 0 ? "text-danger" : (item.AlertThreshold > 0 && item.Quantity <= item.AlertThreshold ? "text-warning" : ""))">@item.Quantity</td>
                        <td class="text-dim">@item.FdaString</td>
                        <td>
                            <a asp-controller="Home" asp-action="Index" asp-route-omniSearch="@item.ItemId" class="btn btn-sm btn-outline-info">
                                Handle Stock
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
