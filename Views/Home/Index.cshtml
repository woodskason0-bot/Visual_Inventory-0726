@using InventoryDevTwo.Services
@inject InventoryDevTwo.Services.CurrentUserService CurrentUser
@functions {
    string GetHoloTitle(InventoryDevTwo.Models.SearchResult result)
    {
        if (result.Mode == "Omni") return $"Omni Search: \"{ViewBag.OmniSearch}\"";
        if (result.Mode == "Filter") return "Filter Search";
        return result.Mode == "Ledger" ? "Order Cart" : "Holo Viewer";
    }

    // Friendly one-line location for a variant: decode coded P/M/S, drop 0/blank
    // levels, append Rack/Row when real. Falls back to the raw FDA string.
    string FriendlyVarLoc(InventoryDevTwo.Models.ItemVariant v)
    {
        bool Real(string? s) => !string.IsNullOrWhiteSpace(s) && s.Trim() != "0";
        var crumbs = new System.Collections.Generic.List<string>();
        if (Real(v.Parent)) crumbs.Add(InventoryDevTwo.Services.LocationCodec.Decode(v.Parent));
        if (Real(v.Major)) crumbs.Add(InventoryDevTwo.Services.LocationCodec.Decode(v.Major));
        if (Real(v.Sub)) crumbs.Add(InventoryDevTwo.Services.LocationCodec.Decode(v.Sub));
        string path = string.Join(" › ", crumbs);
        string rr = "";
        if (Real(v.Rack) || Real(v.Row))
            rr = $"R{(Real(v.Rack) ? v.Rack.Trim() : "-")}/{(Real(v.Row) ? v.Row.Trim() : "-")}";
        if (path == "" && rr == "") return string.IsNullOrWhiteSpace(v.FdaString) ? "-" : v.FdaString;
        return rr == "" ? path : (path == "" ? rr : $"{path} · {rr}");
    }

    // Truncate an item name to a max number of NON-space characters, then add an ellipsis.
    string TruncName(string name, int maxNonSpace)
    {
        if (string.IsNullOrEmpty(name)) return "";
        int nonSpace = 0;
        var sb = new System.Text.StringBuilder();
        foreach (char c in name)
        {
            if (!char.IsWhiteSpace(c))
            {
                if (nonSpace == maxNonSpace) return sb.ToString().TrimEnd() + "...";
                nonSpace++;
            }
            sb.Append(c);
        }
        return sb.ToString();
    }
}

@{
    ViewData["Title"] = "Command Center";
    var result = ViewBag.SearchResult as InventoryDevTwo.Models.SearchResult;
    bool showHolo = result != null && result.Mode != "None";
    var headerDraftIds = ViewBag.DraftItemIds as System.Collections.Generic.HashSet<string>;
    var hasDraft = headerDraftIds != null && headerDraftIds.Any();

    var invSvc = ViewBag.InventoryService as InventoryDevTwo.Services.InventoryService;
    var allItems = invSvc?.GetAll() ?? new List<InventoryDevTwo.Models.InventoryItem>();

    var lowStockItems = allItems.Where(i => i.AlertThreshold > 0 && i.Quantity <= i.AlertThreshold).OrderBy(i => i.Quantity).ToList();
    var recentActivity = ViewBag.RecentActivity as List<InventoryDevTwo.Models.TransactionLog> ?? new List<InventoryDevTwo.Models.TransactionLog>();

    // A location segment only "counts" if it's present and not the 0 placeholder.
    // Used for the map drill-down so 0-filled levels (e.g. PATS.0.0.0.0) never show.
    Func<string, bool> realSeg = s => !string.IsNullOrWhiteSpace(s) && s.Trim() != "0";

    // One rule per zone, keyed by code. Parent stores the code and the
    // FdaString always begins with it, so a single matcher covers both.
    Func<string, object> zone = code =>
    {
        var items = allItems.Where(i => i.Parent == code
            || (i.FdaString != null && i.FdaString.StartsWith(code))).ToList();
        return new
        {
            TotalRows = items.Count,
            HasAlert = items.Any(i => i.AlertThreshold > 0 && i.Quantity <= i.AlertThreshold),
            // Majors exclude 0/blank. Each Major carries its real (non-0) Subs so the
            // menu can drill one level deeper: Parent -> Major -> Sub (hard stop; Row/Rack
            // are never their own click level).
            Majors = items.Where(i => realSeg(i.Major))
                          .GroupBy(i => i.Major)
                          .ToDictionary(g => g.Key, g => new {
                              Rows = g.Count(),
                              HasAlert = g.Any(i => i.AlertThreshold > 0 && i.Quantity <= i.AlertThreshold),
                              Subs = g.Where(i => realSeg(i.Sub))
                                      .GroupBy(i => i.Sub)
                                      .ToDictionary(sg => sg.Key, sg => new {
                                          Rows = sg.Count(),
                                          HasAlert = sg.Any(i => i.AlertThreshold > 0 && i.Quantity <= i.AlertThreshold)
                                      })
                          })
        };
    };

    var mapData = new Dictionary<string, object>
    {
        { "RD Lab", zone("RLB") },
        { "External Yard", zone("ETRD") },
        { "New Test Cells", zone("NWES") },
        { "Plant Test Cells", zone("PATS") }
    };
    var mapDataJson = System.Text.Json.JsonSerializer.Serialize(mapData);

    // Coded location hierarchy (Parent -> Major -> [Subs]) built from the REAL stored
    // values, so the Location Transfer cascade always matches what's in the DB (codes,
    // e.g. ETRD -> CNEA -> CNE6) and can seed an item's current location cleanly.
    var locHierarchy = allItems
        .Where(i => realSeg(i.Parent))
        .GroupBy(i => i.Parent)
        .ToDictionary(pg => pg.Key, pg => pg
            .Where(i => realSeg(i.Major))
            .GroupBy(i => i.Major)
            .ToDictionary(mg => mg.Key, mg => mg
                .Where(i => realSeg(i.Sub))
                .Select(i => i.Sub).Distinct().OrderBy(s => s).ToList()));
    var locHierarchyJson = System.Text.Json.JsonSerializer.Serialize(locHierarchy);
    // Code -> friendly map so the client map drill can show names, not codes.
    var locDecodeJson = System.Text.Json.JsonSerializer.Serialize(InventoryDevTwo.Services.LocationCodec.DecodeMap);
}

<style>
    /* 1. GRID COLUMN ADJUSTMENT (Sidebars expanded to 380px) */
    .overlay-grid, .selection-grid {
        position: fixed;
        top: var(--vis-header-bottom, 110px);
        bottom: 12px;
        left: 12px;
        right: 12px;
        display: grid;
        /* Widened outer tracks to 380px */
        grid-template-columns: 380px repeat(4, 1fr) 380px;
        grid-template-rows: min-content 1fr 1fr 1fr;
        gap: 16px;
        z-index: 100;
    }

        /* Force specific cell coordinates to persist even if external styles compete */
        .overlay-grid .r1 {
            grid-row-start: 1 !important;
        }

        .overlay-grid .r2 {
            grid-row-start: 2 !important;
        }

        .overlay-grid .r3 {
            grid-row-start: 3 !important;
        }

        .overlay-grid .r4 {
            grid-row-start: 4 !important;
        }

        .overlay-grid .c1 {
            grid-column-start: 1 !important;
        }

        .overlay-grid .c2 {
            grid-column-start: 2 !important;
        }

        .overlay-grid .c3 {
            grid-column-start: 3 !important;
        }

        .overlay-grid .c4 {
            grid-column-start: 4 !important;
        }

        .overlay-grid .c5 {
            grid-column-start: 5 !important;
        }

        .overlay-grid .c6 {
            grid-column-start: 6 !important;
        }

    /* Completely hide the background diagnostic guide grid */
    .selection-grid {
        display: none !important;
    }

    .selection-cell {
        border: 1px dashed rgba(245, 166, 35, 0.15) !important;
        background: rgba(245, 166, 35, 0.01);
        color: rgba(255, 255, 255, 0.15);
        font-size: 13px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* 2. HOLO VIEW MODAL & BACKDROP CORRECTIONS */
    .holo-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(10, 11, 14, 0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }

    /* Bootstrap modals must sit ABOVE the holo overlay (z-index 2000),
       otherwise modals opened from inside the cart view are hidden behind it. */
    .modal {
        z-index: 2200 !important;
    }

    .modal-backdrop {
        z-index: 2150 !important;
    }

    .holo-viewer {
        display: grid;
        grid-template-columns: 1fr 280px !important;
        grid-template-rows: auto 1fr;
        width: 80vw !important;
        max-width: 1200px;
        height: 80vh !important;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }

    .holo-header {
        grid-column: 1 / span 2 !important;
        grid-row: 1 !important;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        background: var(--vis-card);
        border-bottom: 2px solid var(--vis-card-border);
    }

    .holo-body {
        grid-column: 1 !important;
        grid-row: 2 !important;
        overflow-y: auto !important; /* Enable list scrolling inside modal container */
        padding: 24px;
        background: var(--vis-bg);
    }

    .holo-actions {
        grid-column: 2 !important;
        grid-row: 2 !important;
        padding: 24px;
        background: var(--vis-card);
        border-left: 1px solid var(--vis-card-border);
        display: flex;
        flex-direction: column;
    }

    /* 3. MAP OVERLAYS (PORTED TO CORRESPOND TO MAP CONTAINER HEIGHT) */
    .map-stats-bar {
        position: absolute;
        bottom: 45px;
        left: 15px;
        right: 15px;
        background: rgba(28, 30, 36, 0.95);
        backdrop-filter: blur(5px);
        border: 1px solid var(--vis-card-border);
        border-radius: 8px;
        padding: 12px 20px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        z-index: 110;
        box-shadow: 0 10px 20px rgba(0,0,0,0.6);
    }

    .map-live-bar {
        position: absolute;
        bottom: 12px;
        left: 20px;
        right: 20px;
        font-size: 13px;
        color: #E2E8F0;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 110;
    }

    /* 4. MODAL HIGH CONTRAST DARK OVERRIDES */
    .modal-content label {
        color: #E2E8F0 !important; /* Highly visible silver-white */
        font-weight: 600 !important;
    }

    /* Ensures both Bootstrap modal subtexts and the Export Wizard card description are visible */
    .modal-content .text-light-gray,
    .modal-content .text-muted,
    .grid-card .text-muted {
        color: #94A3B8 !important; /* Brightened visible slate-gray */
    }

    .modal-content input,
    .modal-content select,
    .modal-content select option {
        background-color: #14151A !important;
        color: #FFFFFF !important;
        border-color: #3D4351 !important;
    }

    /* Utility text overrides */
    .text-light-gray {
        color: #CBD5E1 !important;
    }

    .text-bright-white {
        color: #FFFFFF !important;
    }
    /* =========================================================
                   MAP INTERACTIVE ZONE & CASCADING MENU STYLES
                   ========================================================= */

    /* 1. The main absolute wrapper for each map coordinate zone */
    .map-zone {
        position: absolute;
        z-index: 120;
        pointer-events: auto; /* Re-enables clicks over the transparent overlay */
        box-sizing: border-box;
        border: 2px solid var(--vis-yellow);
        border-radius: 4px;
        background: rgba(245, 166, 35, 0.10);
        box-shadow: inset 0 0 0 1px rgba(0,0,0,0.35), 0 0 12px rgba(245,166,35,0.15);
        transition: background 0.18s ease, box-shadow 0.18s ease;
    }

        .map-zone:hover {
            background: rgba(245, 166, 35, 0.22);
            box-shadow: inset 0 0 0 1px rgba(0,0,0,0.35), 0 0 18px rgba(245,166,35,0.35);
        }

        /* Zones holding a low-stock item glow red instead of yellow */
        .map-zone.alert-zone {
            border-color: var(--vis-red);
            background: rgba(216, 43, 51, 0.12);
            box-shadow: inset 0 0 0 1px rgba(0,0,0,0.35), 0 0 14px rgba(216,43,51,0.30);
        }

            .map-zone.alert-zone:hover {
                background: rgba(216, 43, 51, 0.22);
            }

        /* Elevates the active popup container to float above adjacent map tags */
        .map-zone.active-zone {
            z-index: 1500 !important;
        }

    /* 2. The interactive pulsing map pin */
    .zone-marker {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--vis-yellow);
        background: rgba(17, 18, 22, 0.85);
        backdrop-filter: blur(3px);
        border: 1px solid var(--vis-yellow);
        padding: 4px 8px;
        border-radius: 6px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
    }

        .zone-marker:hover {
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(245, 166, 35, 0.6);
            z-index: 130;
        }

    .marker-icon {
        font-size: 18px;
        line-height: 1;
    }

    .marker-count {
        font-size: 10px;
        font-weight: 700;
        white-space: nowrap;
        margin-top: 2px;
    }

    /* Pulsing animation for zones with active alerts */
    .alert-pulse {
        border-color: var(--vis-red) !important;
        color: var(--vis-red) !important;
        animation: pulse-border 2s infinite;
    }

    @@keyframes pulse-border {
        0% {
            box-shadow: 0 0 0 0 rgba(216, 43, 51, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(216, 43, 51, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(216, 43, 51, 0);
        }
    }

    /* 3. The Cascading Location Dropdown Menu (Hidden by default) */
    .zone-menu {
        display: none; /* Keep hidden until clicked */
        position: absolute;
        min-width: 220px;
        background: rgba(28, 30, 36, 0.98);
        backdrop-filter: blur(10px);
        border: 1px solid var(--vis-card-border);
        border-radius: 8px;
        padding: 8px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.7);
        z-index: 1000;
        flex-direction: column;
        gap: 6px;
    }

        /* Display flex when toggled active via JS */
        .zone-menu.show {
            display: flex !important;
        }

    .zone-menu-header {
        font-size: 11px;
        font-weight: 800;
        color: var(--vis-yellow);
        text-transform: uppercase;
        padding: 6px 12px;
        border-bottom: 1px solid var(--vis-card-border);
        margin-bottom: 4px;
        letter-spacing: 0.5px;
    }

    /* Buttons inside the dropdown menus */
    .zone-menu-btn {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding: 8px 12px;
        background: #14151A;
        border: 1px solid #2D3139;
        color: #E2E8F0;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        text-align: left;
        transition: all 0.2s ease;
    }

        .zone-menu-btn:hover {
            background: #2A2D35;
            border-color: #3D4351;
            color: #FFFFFF;
        }

        .zone-menu-btn .badge {
            font-size: 10px;
            background-color: #3A3F4B !important;
            color: #CBD5E1 !important;
        }

    /* Cascading menu placement offsets calculated by JS positioning classes */
    .zone-menu.menu-down {
        top: 100%;
        margin-top: 8px;
    }

    .zone-menu.menu-up {
        bottom: 100%;
        margin-bottom: 8px;
    }

    .zone-menu.menu-left {
        right: 0;
    }

    .zone-menu.menu-right {
        left: 0;
    }

    .zone-menu.menu-center {
        left: 50%;
        transform: translateX(-50%);
    }

    /* Map drill: a Major that has real (non-0) Subs becomes an expandable group.
       The nested list lives inside .zone-menu (z-index 1000, under holo overlay 2000),
       so no new stacking context is introduced. */
    .zone-major-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .zone-submenu {
        display: none;
        flex-direction: column;
        gap: 6px;
        margin: 0 0 2px 8px;
        padding-left: 10px;
        border-left: 2px solid var(--vis-yellow);
    }

        .zone-major-group.open > .zone-submenu {
            display: flex;
        }

    .zone-subbtn {
        background: #0F1014;
        font-weight: 500;
    }

    .zone-chev {
        font-size: 10px;
        transition: transform 0.18s ease;
        margin-left: 6px;
    }

        .zone-major-group.open .zone-chev {
            transform: rotate(180deg);
        }

    /* Activity Feed Vertical Timeline Structure */
    .activity-feed {
        border-left: 2px solid var(--vis-card-border);
        margin-left: 10px;
        padding-left: 15px;
        position: relative;
    }

    .activity-item {
        position: relative;
        margin-bottom: 12px;
    }

    .activity-dot {
        position: absolute;
        left: -21px; /* Center dot over the timeline line perfectly */
        top: 4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    /* Glowing Red Dot Tracking along its glide path */
    .glowing-tracker-dot {
        position: absolute;
        width: 10px;
        height: 10px;
        background-color: var(--vis-red);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--vis-red), 0 0 20px var(--vis-red);
        z-index: 115;
        pointer-events: none;
        transition: left 2s ease-in-out, top 2s ease-in-out; /* Smooth transition */
    }
</style>

<!-- HTTP Warning -->
<div id="http-warning" class="alert alert-warning floating-alert" style="display:none; top: 80px;">
    <strong>Warning:</strong> You are using HTTP. Form submissions will fail! Please switch to HTTPS.
</div>

<!-- 2. BACKGROUND GUIDE GRID (RE-ENABLED) -->
<div class="selection-grid" id="placement-grid">
    @for (int i = 1; i <= 24; i++)
    {
        <div class="selection-cell">@i</div>
    }
</div>

<!-- 3. MAIN UI OVERLAY GRID -->
<div class="overlay-grid">

    <!-- Cells 1 & 2: Filters -->
    <div class="grid-item r1 c1 col-span-2 grid-card">
        <label class="text-bright-white fw-bold mb-2">Advanced Filters</label>
        <form asp-action="Index" method="get" class="d-flex flex-column h-100">
            <div class="filter-grid mb-2">
                <input name="filterName" placeholder="Name" class="form-control" value="@ViewBag.FilterName" />
                <input name="filterType" placeholder="Type" class="form-control" value="@ViewBag.FilterType" />
                <input name="filterBrand" placeholder="Brand" class="form-control" value="@ViewBag.FilterBrand" />
                <input name="filterNotes" placeholder="FDA Term" class="form-control" value="@ViewBag.FilterNotes" />
            </div>
            <div class="d-flex gap-2 mt-auto">
                <button type="submit" class="btn btn-primary w-100 fw-bold">Apply Filters</button>
                <a href="/Home/Index" class="btn btn-outline-secondary text-white fw-bold">Clear</a>
            </div>
        </form>
    </div>

    <!-- Cell 3: Omni Search -->
    <div class="grid-item r1 c3 grid-card">
        <label class="text-bright-white fw-bold mb-2">Omni Search</label>
        <form asp-action="Index" method="get" class="d-flex flex-column h-100">
            <input name="omniSearch" placeholder="Search ID / Brand / Location..." class="form-control mb-2" value="@ViewBag.OmniSearch" />
            <button type="submit" class="btn btn-outline-primary w-100 mb-1 fw-bold">GO TO →</button>
            <div class="mt-auto small text-light-gray">Items: @allItems.Count()</div>
        </form>
    </div>

    <!-- Cell 4: Export -->
    <div class="grid-item r1 c4 grid-card">
        <div class="d-flex flex-column h-100">
            <div class="mb-1">
                <label class="text-bright-white fw-bold d-block" style="font-size: 14px;">Export Wizard</label>
                <small class="d-block text-muted" style="font-size: 10px; line-height: 1.2;">
                    Options: Group, Team, Type, Brand, Location
                </small>
            </div>
            <div class="mt-auto">
                <button type="button" class="btn btn-sm btn-dark w-100 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#exportWizardModal">
                    <i class="bi bi-file-earmark-arrow-down"></i> CSV
                </button>
            </div>
        </div>
    </div>

    <!-- Cell 5: Advanced Transactions / Modify Stock -->
    <div class="grid-item r1 c5 grid-card">
        <div class="d-flex flex-column h-100">
            <div class="mb-2">
                <label class="text-bright-white fw-bold d-block">Modify Stock</label>
                <small class="d-block text-light-gray" style="line-height: 1.3;">Add, Scrap, Adjust, Transfer</small>
            </div>
            <div class="mt-auto">
                @if (CurrentUser.Level >= AccessLevels.Standard)
                {
                    <button type="button" class="btn btn-outline-primary w-100 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#modifyStockModal">
                        <i class="bi bi-tools-fill"></i> Transactions
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary w-100 py-2 fw-bold" disabled title="Requires Standard access">
                        <i class="bi bi-lock-fill"></i> View Only
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Cell 6: Pickup (Big Yellow Box) -->
    <div class="grid-item r1 c6">
        <a asp-controller="Home" asp-action="PickupQueue" class="grid-card pickup-box h-100 w-100 text-center text-decoration-none fw-bold text-white">
            <div>
                <i class="bi bi-box-seam me-2"></i> Pick Up Orders
            </div>
        </a>
    </div>

    <!-- Sidebar Left: Orders & Live Alerts -->
    <div class="grid-item r2 c1 row-span-3 d-flex flex-column gap-2">
        @* Pickup requests live on the Tasks Available board ("Go Get These"),
           not in this sidebar. This column holds the cart/orders buttons. *@
        @if (CurrentUser.Level >= AccessLevels.Engineer)
        {
            <form asp-action="Index" method="get">
                <input type="hidden" name="mode" value="Ledger" />
                <button type="submit" class="btn btn-info w-100 py-3 fw-bold text-white">
                    <i class="bi bi-cart3 me-2"></i> VIEW CART
                </button>
            </form>
        }

        <a asp-controller="Home" asp-action="Orders" class="btn btn-outline-info w-100 py-2 mb-2 fw-bold text-white">
            <i class="bi bi-clock-history me-2"></i> VIEW ORDERS
        </a>

        <!-- LIVE STOCK ALERTS FEED (CLEAN IN-FEED SCROLL VIEW) -->
        <div class="flex-grow-1 border rounded d-flex flex-column overflow-hidden vis-feed-panel" style="border-color: var(--vis-yellow) !important; background-color: #1A1C20; max-height: 280px;">
            <div class="fw-bold small p-2 px-3 d-flex justify-content-between align-items-center" style="background-color: var(--vis-yellow); color: #000;">
                <span><i class="bi bi-exclamation-triangle-fill me-1"></i> Stock Alerts</span>
                <div>
                    <button type="button" class="btn btn-sm text-dark p-0 me-2" data-bs-toggle="modal" data-bs-target="#modifyAlertsModal" title="Modify Alert Rules">
                        <i class="bi bi-gear-fill fs-6"></i>
                    </button>
                    <span class="badge bg-danger text-white fs-6 fw-bold">@lowStockItems.Count</span>
                </div>
            </div>

            <div class="p-2 overflow-auto" style="flex-grow: 1; font-size: 11px;">
                @if (lowStockItems.Any())
                {
                    foreach (var item in lowStockItems)
                    {
                        <a href="/Home/Index?omniSearch=@item.ItemId" class="d-block text-decoration-none p-2 mb-1 rounded vis-alert-row" style="background: rgba(255,255,255,0.03); color: #E2E8F0; transition: background 0.2s; border: 1px solid #2A2D35;">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold text-white text-truncate" style="max-width: 120px;">@item.ItemName</span>
                                <span class="text-warning fw-bold">Qty: @item.Quantity</span>
                            </div>
                            <div style="font-size: 10px; color: var(--vis-text-muted);">Loc: @item.Parent / @item.Major</div>
                        </a>
                    }
                }
                else
                {
                    <div class="text-muted text-center p-4">
                        <i class="bi bi-shield-check d-block mb-2 text-success fs-1"></i>
                        <span class="text-light-gray">Stock levels healthy.</span>
                    </div>
                }
            </div>
        </div>

        <div class="mt-2 d-flex flex-column gap-2">
            @if (CurrentUser.Level >= AccessLevels.Engineer)
            {
                <button type="button" class="btn btn-success w-100 py-2 fw-bold text-white" style="background-color: var(--vis-green); border-color: var(--vis-green);" data-bs-toggle="modal" data-bs-target="#newItemModal">
                    <i class="bi bi-plus-square me-2"></i> New Item Registry
                </button>
                <button type="button" class="btn btn-danger w-100 py-2 fw-bold text-white" data-bs-toggle="modal" data-bs-target="#confirmResetModal">Clear My Cart</button>
            }
        </div>
    </div>

    <!-- THE MAP -->
    <div class="grid-item r2 c2 col-span-4 row-span-3 map-container">
        <div class="map-image-frame">
            <img src="~/images/facility.png" id="facility-map-img" alt="Facility Map" usemap="#labmap" />
            <!-- Reinstated Glowing Red Dot Tracker Element -->
            <div id="map-tracking-dot" class="glowing-tracker-dot"></div>

            <map name="labmap" id="labmap">
                <area shape="rect" coords="1025,370,1110,520" href="/Home/Index?mode=Omni&omniSearch=RLB" title="RD Lab" />
                <area shape="rect" coords="210,45,320,365" href="/Home/Index?mode=Omni&omniSearch=ETRD" title="External Yard" />
                <area shape="rect" coords="975,165,1010,260" href="/Home/Index?mode=Omni&omniSearch=NWES" title="New Test Cells" />
                <area shape="rect" coords="975,455,1010,480" href="/Home/Index?mode=Omni&omniSearch=PATS" title="Plant Test Cells" />
            </map>
        </div>

        <!-- Corrected Stats Dashboard -->
        <div class="map-stats-bar">
            <div class="stat-block">
                <i class="bi bi-box-seam stat-icon text-bright-white"></i>
                <div class="stat-text">
                    <span class="stat-value text-bright-white">@allItems.Count()</span>
                    <span class="stat-label">Total Items</span>
                </div>
            </div>
            <div class="stat-block">
                <i class="bi bi-geo-alt-fill stat-icon text-success"></i>
                <div class="stat-text">
                    <!-- Calculates distinct Parent values dynamically from the SQLite context -->
                    <span class="stat-value text-success">@allItems.Where(i => !string.IsNullOrEmpty(i.Parent)).Select(i => i.Parent).Distinct().Count()</span>
                    <span class="stat-label">Active Locations</span>
                </div>
            </div>
            <div class="stat-block">
                <i class="bi bi-exclamation-triangle-fill stat-icon text-warning"></i>
                <div class="stat-text">
                    <span class="stat-value text-warning">@lowStockItems.Count</span>
                    <span class="stat-label">Low Stock</span>
                </div>
            </div>
            <div class="stat-block">
                <i class="bi bi-x-octagon-fill stat-icon text-danger"></i>
                <div class="stat-text">
                    <span class="stat-value text-danger">@allItems.Count(i => i.Quantity == 0)</span>
                    <span class="stat-label">Out of Stock</span>
                </div>
            </div>
        </div>

        <!-- Live Tracking Status Bar -->
        <div class="map-live-bar d-flex align-items-center">
            <div class="blinking-dot me-2"></div>
            <span class="text-white fw-bold me-2" style="font-size: 12px; letter-spacing: 0.5px;">Live Tracking Active</span>

            <span class="mx-2 text-muted" style="opacity: 0.4;">|</span>

            <span class="text-muted" style="font-size: 11px; font-weight: 500; color: #94A3B8 !important;">
                Last Updated: <span id="last-updated-time">--:--:--</span>
            </span>

            <i class="bi bi-arrow-clockwise ms-2 text-muted" style="cursor: pointer; font-size: 12px;" onclick="location.reload();" title="Refresh Feed"></i>
        </div>
    </div>

    <!-- Quick Filters & Activity Feed (Right Sidebar) -->
    <div class="grid-item r2 c6 row-span-3 grid-card d-flex flex-column gap-1">
        <label class="small fw-bold border-bottom mb-2 p-1">Quick Filters</label>
        <a href="/Home/Index?mode=Filter&filterType=Unit" class="btn btn-sm btn-outline-primary py-2">Units</a>
        <a href="/Home/Index?mode=Filter&filterType=Compressor" class="btn btn-sm btn-outline-primary py-2">Compressors</a>
        <a href="/Home/Index?mode=Filter&filterType=Motor" class="btn btn-sm btn-outline-primary py-2">Motors</a>
        <hr class="my-1" />
        <a href="/Home/Index?mode=Omni&omniSearch=Commercial" class="btn btn-sm btn-outline-secondary py-1">Commercial</a>
        <a href="/Home/Index?mode=Omni&omniSearch=Residential" class="btn btn-sm btn-outline-secondary py-1">Residential</a>

        <!-- LIVE HISTORY TIMELINE FEED (ACTIVITY FEED) -->
        <div class="flex-grow-1 border rounded d-flex flex-column overflow-hidden mt-2 vis-feed-panel" style="border-color: var(--vis-card-border) !important; background-color: #1A1C20;">
            <div class="fw-bold small p-2 px-3 d-flex flex-column" style="background-color: var(--vis-card-border); border-bottom: 1px solid var(--vis-card-border);">
                <span class="text-white fs-5 fw-bold">Activity Feed</span>
                <span class="text-muted" style="font-size: 11px; font-weight: 500; color: #94A3B8 !important;">Live updates from your system</span>
            </div>

            <div class="p-3 overflow-auto" style="flex-grow: 1; font-size: 11px;">
                @if (recentActivity.Any())
                {
                    <div class="activity-feed">
                        @for (int idx = 0; idx < recentActivity.Count; idx++)
                        {
                            var log = recentActivity[idx];
                            var item = invSvc?.GetById(log.ItemId);

                            // Map DB actions to human-friendly operation titles
                            string actionTitle =
                                log.ActionType == "Add" || log.ActionType == "Quick Add" ? "Stock Added" :
                                log.ActionType == "Scrap" ? "Item Scrapped" :
                                log.ActionType == "Ownership" ? "Item Moved" :
                                log.ActionType == "Location Transfer" ? "Item Relocated" :
                                log.ActionType == "New Registry" ? "New Item" :
                                log.ActionType == "Order Picked Up" ? "Order Picked Up" :
                                "Stock Adjusted";

                            // Timestamps are stored UTC; convert to local before
                            // display and before the "today" check so the feed
                            // matches the live tracking bar's local clock.
                            var localTs = log.Timestamp.ToLocalTime();
                            string timeDisplay = localTs.Date == DateTime.Today ?
                                                 localTs.ToString("h:mm tt") :
                                                 localTs.ToString("h:mm tt MM/dd/yyyy");

                            // Dot color by action type (same in both themes).
                            string dotColor =
                                log.ActionType == "Add" || log.ActionType == "Quick Add" ? "#22C55E" : // green  - added
                                log.ActionType == "Scrap" ? "#D82B33" :                                // red    - scrapped
                                log.ActionType == "Ownership" ? "#A855F7" :                            // purple - moved
                                log.ActionType == "Location Transfer" ? "#0EA5E9" :                     // cyan   - relocated
                                log.ActionType == "New Registry" ? "#148A8A" :                         // teal   - new item
                                log.ActionType == "Order Picked Up" ? "#F59E0B" :                      // amber  - picked up
                                "#3B82F6";                                                             // blue   - adjusted
                            string glowStyle = $"background-color: {dotColor} !important; box-shadow: 0 0 8px {dotColor} !important;";

                            <div class="activity-item d-flex justify-content-between align-items-start mb-3">
                                <!-- Activity dot, colored by action type -->
                                <div class="activity-dot" style="@glowStyle"></div>

                                <div style="padding-right: 12px; flex-grow: 1;">
                                    <strong class="text-bright-white d-block" style="font-size: 13px; font-weight: 700;">@actionTitle</strong>
                                    <small class="text-muted d-block mt-1" style="font-size: 11px; color: #94A3B8 !important;">@log.ItemId: @TruncName(item?.ItemName ?? "Unknown item", 15)</small>
                                </div>

                                <div class="text-end text-muted" style="font-size: 11px; white-space: nowrap; color: #94A3B8 !important;">
                                    <div>@timeDisplay</div>
                                    <div style="font-size: 10px; margin-top: 2px;"><i class="bi bi-person-fill me-1"></i>@log.User</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted text-center p-4">
                        <i class="bi bi-journal-x d-block mb-2 text-muted fs-3"></i>
                        <span class="text-light-gray">No activity logged today.</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- 4. HOLOVIEWER MODAL -->
@if (showHolo)
{
    <div class="holo-overlay">
        <div class="holo-viewer" data-mode="@result.Mode">
            <div class="holo-header">
                <h3>@GetHoloTitle(result)</h3>
                <a href="/Home/Index?mode=None&omniSearch=@ViewBag.OmniSearch&filterName=@ViewBag.FilterName" class="btn-close"></a>
            </div>
            <div class="holo-body">
                @if (result.Mode == "Ledger")
                {
                    var ledger = ViewBag.Ledger as InventoryDevTwo.Models.LedgerViewModel;
                    if (ledger != null && ledger.Entries.Any())
                    {
                        foreach (var entry in ledger.Entries)
                        {
                            var item = invSvc?.GetById(entry.ItemId);
                            <div class="holo-row" data-item-id="@entry.ItemId" tabindex="0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong class="text-white fs-5">@(item?.ItemName ?? "Unknown Item")</strong> <span class="text-light-gray ms-2">(ID: @entry.ItemId)</span><br />
                                        <small class="text-light-gray">@(item?.Type ?? "-") | @(item?.Brand ?? "-")</small>
                                    </div>
                                    <div class="text-end">
                                        <span class="holo-qty fs-4">Qty: @entry.Quantity</span>
                                        @if (InventoryDevTwo.Services.InventoryService.IsMotorType(item?.Type) && entry.ThermocoupledCount > 0)
                                        {
                                            <span class="fw-bold ms-2" style="color:#F59E0B;">TC Ct: @entry.ThermocoupledCount</span>
                                        }
                                        <br />
                                        <form asp-action="RemoveFromLedger" method="post" class="mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@entry.ItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">Remove</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {

                        <div class="text-muted text-center mt-5 fs-5">Cart is empty.</div>
                    }
                }
                else if (result.HasResults)
                {
                    foreach (var item in result.Items)
                    {
                        bool inDraft = headerDraftIds != null && headerDraftIds.Contains(item.ItemId);
                        var actVars = item.ActiveVariants.OrderBy(v => v.VariantNumber).ToList();
                        <div class="holo-row" data-item-id="@item.ItemId" tabindex="0">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong class="text-white fs-5">@item.ItemName</strong> <span class="text-light-gray ms-2">(ID: @item.ItemId)</span><br />
                                    @{ bool itemIsMotor = InventoryDevTwo.Services.InventoryService.IsMotorType(item.Type); }
                                    <small class="text-light-gray">@item.Type | Stock: @item.Quantity@(itemIsMotor ? $" | TC Qty: {item.TotalThermocoupled}" : "")</small>
                                    <span class="text-success fw-bold d-block mt-1">Available: @(invSvc != null ? invSvc.GetAvailableQuantity(item.ItemId) : item.Quantity)</span>
                                    @if (actVars.Count > 1)
                                    {
                                        foreach (var v in actVars)
                                        {
                                            <small class="d-block" style="font-size: 10px; color: var(--vis-text-muted);">
                                                <i class="bi bi-geo-alt me-1"></i>Variant @v.VariantNumber — @FriendlyVarLoc(v) · Qty @v.Quantity@(itemIsMotor ? $" · TC {v.ThermocoupledQty}" : "")
                                            </small>
                                        }
                                    }
                                    else
                                    {
                                        <small class="d-block" style="font-size: 10px; color: var(--vis-text-muted); opacity: 0.75;">No variants of item</small>
                                    }
                                </div>
                                <div class="d-flex flex-column align-items-end gap-2">
                                    @if (CurrentUser.Level >= AccessLevels.Engineer)
                                    {
                                        @if (!inDraft)
                                        {
                                            <button type="button" class="btn btn-primary px-3 py-2 fw-bold" onclick="openAddToCart('@item.ItemId')">
                                                <i class="bi bi-cart-plus me-1"></i> Add to Cart
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary p-2 fs-6 fw-bold">In Cart</span>
                                        }
                                    }
                                    @if (CurrentUser.Level >= AccessLevels.Standard)
                                    {
                                        <button type="button" class="btn btn-outline-info btn-sm fw-bold px-3" onclick="handleStock('@item.ItemId')">
                                            <i class="bi bi-box-seam me-1"></i> Handle Stock
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="text-end mt-1">
                                <small class="text-light-gray" style="font-size: 10px; opacity: 0.7;">
                                    <i class="bi bi-clock-history me-1"></i>Registered: @(item.RegisteredAt.HasValue ? item.RegisteredAt.Value.ToLocalTime().ToString("MMM d, yyyy") : "unknown")
                                </small>
                            </div>
                        </div>
                    }
                }
                else
                {

                    <div class="text-muted text-center mt-5 fs-5">No results found.</div>
                }
            </div>
            <div class="holo-actions">
                @if (result.Mode == "Ledger")
                {
                    <button type="button" class="btn btn-success w-100 py-3 fs-5 fw-bold mb-2" data-bs-toggle="modal" data-bs-target="#confirmSubmitModal">Submit Order</button>
                    <form asp-controller="Home" asp-action="CancelOrder" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100 py-2 fw-bold">Cancel Order (Clear Cart)</button>
                    </form>
                }
                else
                {
                    <div class="text-center text-light-gray p-3">
                        <i class="bi bi-arrow-left-circle d-block mb-2 fs-3"></i>
                        <div class="small">Set a quantity and click <strong>Add to Order</strong> on each item you need, then open your cart to submit.</div>
                    </div>
                }
                <a href="/Home/Index?mode=None&omniSearch=@ViewBag.OmniSearch" class="btn btn-outline-secondary w-100 mt-3 py-2 text-white fw-bold">Close Viewer</a>
            </div>
        </div>
    </div>
}

<!-- 5. ALL MODALS -->
<div class="modal fade" id="confirmSubmitModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Home" asp-action="SubmitLedger" method="post" id="submit-frm">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5>Confirm Final Order</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body text-white">Are you sure you want to submit this order?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Back</button>
                    <button type="button" class="btn btn-success fw-bold" onclick="executeSubmit('submit-frm', this)">Submit Now</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Themed confirm for starting an order on first add (replaces native confirm) -->
<div class="modal fade" id="startOrderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--vis-card); border: 1px solid var(--vis-card-border);">
            <div class="modal-header" style="border-bottom: 1px solid var(--vis-card-border);">
                <h5 class="modal-title fw-bold text-white"><i class="bi bi-cart-plus me-2" style="color: var(--vis-green);"></i>Start an Order?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-white">
                This will start an order and open an active cart. You can keep adding items, then submit when you're ready.
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--vis-card-border);">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Back</button>
                <button type="button" id="startOrderConfirmBtn" class="btn btn-success fw-bold"><i class="bi bi-check2 me-1"></i> Continue</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmResetModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Home" asp-action="SystemReset" method="post" id="reset-frm">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title text-danger fw-bold">Clear Session Cart</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body text-white">This will empty your personal shopping cart. Proceed?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="executeSubmit('reset-frm', this)">Clear Cart</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modifyStockModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Home" asp-action="ModifyStock" method="post" id="modify-stock-frm">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-tools me-2"></i>Modify Stock</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-white">
                    <div class="mb-3 position-relative">
                        <label class="form-label small fw-bold text-light-gray">Search Item</label>
                        <input type="text" id="stock-search" class="form-control" placeholder="Type ID or Name..." autocomplete="off" />
                        <div id="stock-autocomplete-list" class="list-group position-absolute w-100 shadow" style="z-index: 2000; display: none; max-height: 200px; overflow-y: auto;"></div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-light-gray">Selected Item ID</label>
                            <input type="text" name="itemId" id="stock-item-id" class="form-control text-white fw-bold" style="background-color: var(--vis-card-border);" readonly required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-light-gray">Action</label>
                            <select name="actionType" id="stock-action-type" class="form-select fw-bold text-primary" onchange="toggleStockUI()">
                                <option value="Add">Add Stock (+)</option>
                                <option value="Adjustment">Adjustment (+/-)</option>
                                <option value="Location Transfer">Location Transfer</option>
                                @if (CurrentUser.Level >= AccessLevels.Engineer)
                                {
                                    <option value="Scrap">Scrap (-)</option>
                                    <option value="Ownership">Internal - Transfer</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- LOCATION / VARIANT picker: which physical stack this action hits.
                         Hidden for single-location items on non-Add actions (posts nothing ->
                         primary variant, old behavior). Add always shows it for the
                         "New location..." option. -->
                    <div id="stock-variant-div" class="mb-3" style="display:none;">
                        <label class="form-label small fw-bold text-light-gray">Location / Variant</label>
                        <select id="stock-variant-sel" name="targetVariant" class="form-select fw-bold text-info"></select>
                        <small class="text-light-gray d-block mt-1" style="font-size:10px;" id="stock-variant-help">Which physical stack this action applies to.</small>
                    </div>

                    <div id="stock-qty-div" class="mb-3">
                        <label class="form-label small fw-bold text-light-gray">Quantity</label>
                        <input type="number" name="quantity" id="stock-qty-input" class="form-control" value="1" required />
                        <small class="text-light-gray" id="stock-qty-help">Amount to ADD to current inventory.</small>
                    </div>

                    <!-- THERMOCOUPLED subset (motors only). One field for Add/Scrap; a
                         twin lives in the transfer move-qty row. Whichever is hidden is
                         DISABLED so exactly one "thermocoupledQty" ever posts. -->
                    <div id="stock-tc-div" class="mb-3" style="display:none;">
                        <label class="form-label small fw-bold" style="color: var(--vis-amber, #F59E0B);">
                            <i class="bi bi-thermometer-half me-1"></i>Thermocoupled
                        </label>
                        <input type="number" name="thermocoupledQty" id="stock-tc-input" class="form-control fw-bold"
                               value="0" min="0" disabled
                               style="border-color:#F59E0B;" />
                        <small class="text-light-gray d-block mt-1" style="font-size:10px;" id="stock-tc-help">How many of these are thermocoupled?</small>
                    </div>

                    <div id="stock-own-div" class="row g-2 mb-3" style="display:none;">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-light-gray">New Group</label>
                            <select name="newGroup" class="form-select">
                                <option value="Commercial">Commercial</option>
                                <option value="Residential">Residential</option>
                                <option value="International">International</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-light-gray">New Team</label>
                            <select name="newTeam" class="form-select">
                                <option value="Samurai">Samurai (7166)</option>
                                <option value="Ninja">Ninja (7165)</option>
                            </select>
                        </div>
                    </div>

                    <!-- LOCATION TRANSFER: item-first. Fields start disabled, then seed from the
                         selected item's current location. 0 = unspecified at every level but Parent. -->
                    <div id="stock-loc-div" class="mb-1" style="display:none;">
                        <div class="py-2 px-3 mb-3 small rounded" style="background:#14151A; border:1px solid #3D4351; color:#94A3B8;">
                            <i class="bi bi-geo-alt me-1"></i> Current location: <span class="fw-bold text-info" id="loc-current">--</span>
                        </div>
                        <div id="loc-needs-item" class="small text-warning mb-2">
                            <i class="bi bi-info-circle me-1"></i> Select an item above to edit its location.
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-light-gray">Parent</label>
                                <select name="newParent" id="loc-parent" class="form-select" disabled>
                                    <option value="">Select Parent...</option>
                                    <option value="RLB">RD Lab (RLB)</option>
                                    <option value="ETRD">External Yard (ETRD)</option>
                                    <option value="NWES">New Test Cells (NWES)</option>
                                    <option value="PATS">Plant Test Cells (PATS)</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-light-gray">Major</label>
