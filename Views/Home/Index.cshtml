<!-- ADD TO CART subprocess modal. One shared instance; openAddToCart(itemId)
     fills it from itemsList. Plain Bootstrap .modal -> inherits the z-index
     registry (2200 over holo overlay 2000). Posts to the same AddToCart action
     Feature 1 already used; no controller/model/migration change. -->
<div class="modal fade" id="addToCartModal" tabindex="-1">
