<!-- 8. SCRIPTS -->
<script>
    function executeSubmit(id, btnElement) {
        const f = document.getElementById(id);
        if (f) {
            if (btnElement) {
                btnElement.disabled = true;
                btnElement.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';
            }
            f.submit();
        }
    }

    // Management-only: validate, then show a styled confirm popup before bulk-
    // setting the alert threshold. We CLOSE the alerts modal first and open the
    // confirm popup only once it's fully hidden, so the two never stack (the app
    // pins every modal to the same z-index, so stacking would misbehave).
    function applyBulkThreshold() {
        const input = document.getElementById('bulk-threshold-input');
        const raw = input ? input.value.trim() : '';
        if (raw === '' || isNaN(raw) || parseInt(raw, 10) < 0) {
            showToast('Enter a valid threshold (0 or higher).', 'error');
            return;
        }
        const val = parseInt(raw, 10);
        document.getElementById('bulk-threshold-value').value = val;

        const msg = document.getElementById('bulk-confirm-msg');
        if (msg) msg.textContent = 'Set the alert threshold to ' + val + ' for all items you oversee? This overwrites every current threshold.';

        const alertsEl = document.getElementById('modifyAlertsModal');
        const confirmEl = document.getElementById('confirmBulkThresholdModal');
        const confirmModal = bootstrap.Modal.getInstance(confirmEl) || new bootstrap.Modal(confirmEl);
        const alertsModal = alertsEl ? (bootstrap.Modal.getInstance(alertsEl) || new bootstrap.Modal(alertsEl)) : null;

        if (alertsModal && alertsEl) {
            alertsEl.addEventListener('hidden.bs.modal', function handler() {
                alertsEl.removeEventListener('hidden.bs.modal', handler);
                confirmModal.show();
            });
            alertsModal.hide();
        } else {
            confirmModal.show();
        }
    }

    // Opens the Modify Stock panel pre-loaded with a specific item (from a search row).
    function handleStock(itemId) {
        const idField = document.getElementById('stock-item-id');
        const searchField = document.getElementById('stock-search');
        if (idField) idField.value = itemId;
        if (searchField) searchField.value = itemId;
        if (typeof toggleStockUI === 'function') toggleStockUI();
        const el = document.getElementById('modifyStockModal');
        if (el) { new bootstrap.Modal(el).show(); }
    }

    // Variants of the item currently shown in the Add to Cart modal (with tcqty),
    // so the TC cap can react to the chosen pull-location.
    let atcCurrentVariants = [];

    // Opens the Add to Cart subprocess modal for a specific item, filling the
    // qty / pull-location / TC controls from itemsList (same data the Modify
    // Stock modal reads). Location select only appears for multi-location items;
    // TC only for motors, capped by the chosen location's actual TC.
    function openAddToCart(itemId) {
        const item = itemsList.find(function (i) { return i.id === itemId; });
        if (!item) return;

        atcCurrentVariants = (item.variants || []);

        document.getElementById('atc-item-id').value = itemId;
        document.getElementById('atc-item-name').textContent = item.name || itemId;
        document.getElementById('atc-item-sub').textContent =
            'ID: ' + itemId + (item.type ? '  ·  ' + item.type : '');

        // Reset the header close button in case a prior add mangled it (the
        // generic add handler retargets the form's first button, which is this X).
        const xbtn = document.querySelector('#add-to-cart-frm .btn-close');
        if (xbtn) { xbtn.textContent = ''; xbtn.disabled = false; }

        // Reset quantity.
        const qty = document.getElementById('atc-qty');
        qty.value = 1;

        // Pull-location selector: only when split across >1 active location.
        const locDiv = document.getElementById('atc-loc-div');
        const locSel = document.getElementById('atc-loc-sel');
        const vars = atcCurrentVariants;
        locSel.innerHTML = '';
        if (vars.length > 1) {
            const either = document.createElement('option');
            either.value = '';
            either.textContent = 'Either location (picker chooses)';
            locSel.appendChild(either);
            vars.forEach(function (v) {
                const o = document.createElement('option');
                o.value = String(v.vid);
                o.textContent = 'V' + v.num + ' — ' + (v.fda || '--') + ' (Qty ' + v.qty + ')';
                locSel.appendChild(o);
            });
            locDiv.style.display = 'block';
        } else {
            // Single location: post nothing -> null -> Either (pulls the one stack).
            locDiv.style.display = 'none';
        }
        // Re-cap TC whenever the pull-location changes.
        locSel.onchange = atcRecomputeTcCap;

        // TC request: motors only. Disabled when hidden so it never posts for
        // non-motors (keeps thermocoupledCount at its 0 default).
        const tcDiv = document.getElementById('atc-tc-div');
        const tc = document.getElementById('atc-tc');
        if (typeof isMotorType === 'function' && isMotorType(item.type)) {
            tc.value = 0;
            tc.disabled = false;
            tcDiv.style.display = 'block';
        } else {
            tc.value = 0;
            tc.disabled = true;
            tcDiv.style.display = 'none';
        }
        atcRecomputeTcCap();

        const el = document.getElementById('addToCartModal');
        if (el) { new bootstrap.Modal(el).show(); }
    }

    // Cap the TC request by the chosen pull-location's ACTUAL thermocoupled stock
    // (and by Add Quantity): a specific stack -> that stack's TC; "Either" -> the
    // total TC across active stacks; single-location -> the one stack's TC. This
    // stops a TC count being attached to a stack that has no TC to give.
    function atcRecomputeTcCap() {
        const tc = document.getElementById('atc-tc');
        if (!tc || tc.disabled) return;
        const qty = parseInt(document.getElementById('atc-qty').value, 10) || 0;
        const sel = document.getElementById('atc-loc-sel');
        const locDiv = document.getElementById('atc-loc-div');
        const vars = atcCurrentVariants || [];

        let availTc = 0;
        if (locDiv && locDiv.style.display !== 'none' && sel) {
            if (sel.value === '') {
                availTc = vars.reduce(function (s, v) { return s + (v.tcqty || 0); }, 0);
            } else {
                const vid = parseInt(sel.value, 10);
                const hit = vars.find(function (v) { return v.vid === vid; });
                availTc = hit ? (hit.tcqty || 0) : 0;
            }
        } else {
            availTc = vars.length ? (vars[0].tcqty || 0) : 0;
        }

        const ceil = Math.max(0, Math.min(qty, availTc));
        tc.max = ceil;
        let v = parseInt(tc.value, 10); if (isNaN(v) || v < 0) v = 0;
        if (v > ceil) v = ceil;
        tc.value = v;
    }

    // ---- Variant helpers -------------------------------------------------
    function getStockItem() {
        const idEl = document.getElementById('stock-item-id');
        const itemId = idEl ? idEl.value : '';
        if (!itemId) return null;
        return itemsList.find(function (i) { return i.id === itemId; }) || null;
    }

    // The variant currently chosen in the selector (never "NEW"); falls back
    // to the item's first (primary) variant.
    function getSelectedVariant(item) {
        if (!item || !item.variants || !item.variants.length) return null;
        const sel = document.getElementById('stock-variant-sel');
        if (sel && sel.value && sel.value !== 'NEW') {
            const vid = parseInt(sel.value, 10);
            const f = item.variants.find(function (v) { return v.vid === vid; });
            if (f) return f;
        }
        return item.variants[0];
    }

    // (Re)build the Location/Variant selector for the current item + action.
    // Shown when the item is split across locations, or on Add (for the
    // "New location..." option). Hidden = posts nothing = primary variant.
    function populateVariantSel(action) {
        const div = document.getElementById('stock-variant-div');
        const sel = document.getElementById('stock-variant-sel');
        const help = document.getElementById('stock-variant-help');
        if (!div || !sel) return;

        const item = getStockItem();
        const vars = (item && item.variants) ? item.variants : [];
        const show = item && (vars.length > 1 || action === 'Add') && action !== 'Ownership';

        sel.innerHTML = '';
        if (!show) { div.style.display = 'none'; return; }

        vars.forEach(function (v) {
            const o = document.createElement('option');
            o.value = String(v.vid);
            o.textContent = 'V' + v.num + ' — ' + (v.fda || '--') + ' (Qty ' + v.qty + ')';
            sel.appendChild(o);
        });
        if (action === 'Add') {
            const o = document.createElement('option');
            o.value = 'NEW';
            o.textContent = '+ New location...';
            sel.appendChild(o);
        }
        if (help) {
            help.textContent = (action === 'Location Transfer')
                ? 'Which stack to move FROM.'
                : (action === 'Add' ? 'Which stack to add to — or start a new location.'
                                    : 'Which physical stack this action applies to.');
        }
        div.style.display = 'block';
    }

    // Transfer only: warn when the destination matches a sibling stack, since
    // executing will MERGE quantities (source retires if fully drained).
    function refreshMergeNote() {
        const note = document.getElementById('loc-merge-note');
        if (!note) return;
        const action = document.getElementById('stock-action-type').value;
        if (action !== 'Location Transfer') { note.style.display = 'none'; return; }

        const item = getStockItem();
        const srcVar = getSelectedVariant(item);
        if (!item || !srcVar) { note.style.display = 'none'; return; }

        const seg = function (id) {
            const el = document.getElementById(id);
            const v = el ? String(el.value || '').trim().toUpperCase() : '';
            return v === '' ? '0' : v;
        };
        const norm = function (v) {
            const s = (v == null ? '' : String(v).trim().toUpperCase());
            return s === '' ? '0' : s;
        };
        const dest = [seg('loc-parent'), seg('loc-major'), seg('loc-sub'), seg('loc-rack'), seg('loc-row')];

        const hit = (item.variants || []).find(function (v) {
            if (v.vid === srcVar.vid) return false;
            return norm(v.parent) === dest[0] && norm(v.major) === dest[1] && norm(v.sub) === dest[2]
                && norm(v.rack) === dest[3] && norm(v.row) === dest[4];
        });

        if (hit) {
            note.innerHTML = '<i class="bi bi-arrow-down-up me-1"></i>Merges into Variant ' + hit.num
                + ' (Qty ' + hit.qty + ') — source retires if fully drained.';
            note.style.display = 'block';
        } else {
            note.style.display = 'none';
        }
    }

    // Prefill "Quantity to move" with the source stack's full amount.
    function refreshMoveQty() {
        const input = document.getElementById('loc-moveqty');
        if (!input) return;
        const srcVar = getSelectedVariant(getStockItem());
        if (srcVar) { input.value = srcVar.qty; input.max = srcVar.qty; }
    }

    function toggleStockUI() {
        const action = document.getElementById('stock-action-type').value;
        const qtyDiv = document.getElementById('stock-qty-div');
        const ownDiv = document.getElementById('stock-own-div');
        const locDiv = document.getElementById('stock-loc-div');
        const moveQtyDiv = document.getElementById('loc-moveqty-div');
        const qtyInput = document.getElementById('stock-qty-input');
        const helpText = document.getElementById('stock-qty-help');

        populateVariantSel(action);
        const variantSel = document.getElementById('stock-variant-sel');
        const addingNew = (action === 'Add' && variantSel && variantSel.value === 'NEW');

        if (action === 'Ownership') {
            qtyDiv.style.display = 'none';
            ownDiv.style.display = 'flex';
            if (locDiv) locDiv.style.display = 'none';
            if (moveQtyDiv) moveQtyDiv.style.display = 'none';
            qtyInput.required = false;
        } else if (action === 'Location Transfer') {
            qtyDiv.style.display = 'none';
            ownDiv.style.display = 'none';
            if (locDiv) locDiv.style.display = 'block';
            if (moveQtyDiv) moveQtyDiv.style.display = 'flex';
            qtyInput.required = false;
            if (typeof seedLocationTransfer === 'function') seedLocationTransfer();
            refreshMoveQty();
            refreshMergeNote();
        } else {
            qtyDiv.style.display = 'block';
            ownDiv.style.display = 'none';
            // Add-to-NEW-location reuses the transfer cascade for the address,
            // but hides the move-qty row (the main Quantity box is the amount).
            if (locDiv) locDiv.style.display = addingNew ? 'block' : 'none';
            if (moveQtyDiv) moveQtyDiv.style.display = 'none';
            qtyInput.required = true;
            if (addingNew) {
                locSetEnabled(true);
                locRefreshFda();
            }

            if (action === 'Add') helpText.innerText = addingNew
                ? "Amount to place at the NEW location."
                : "Amount to ADD to current inventory.";
            else if (action === 'Scrap') helpText.innerText = "Amount to REMOVE from inventory.";
            else if (action === 'Adjustment') helpText.innerText = "Use negative numbers (-) to subtract, positive to add.";
        }

        refreshTcFields(action);
    }

    // ---- Thermocoupled (motors only) -------------------------------------
    // Keep in lockstep with InventoryService.IsMotorType: a type ending in
    // "Motor" (Motor / ID Motor / OD Motor) is TC-eligible; nothing else is.
    function isMotorType(t) {
        return !!t && String(t).trim().toLowerCase().endsWith('motor');
    }

    // Show/enable exactly the right TC input for the action, and cap it so the
    // human can never enter an impossible number. Disabled inputs don't post,
    // so the hidden twin stays out of the way. Add/Scrap use #stock-tc-input;
    // Location Transfer uses #loc-tc-input.
    function refreshTcFields(action) {
        const item = getStockItem();
        const motor = item && isMotorType(item.type);

        const stockDiv = document.getElementById('stock-tc-div');
        const stockInput = document.getElementById('stock-tc-input');
        const stockHelp = document.getElementById('stock-tc-help');
        const locDiv = document.getElementById('loc-tc-div');
        const locInput = document.getElementById('loc-tc-input');
        const locHelp = document.getElementById('loc-tc-help');

        // Default: both off. We turn on only what applies below.
        const off = function (div, input) {
            if (div) div.style.display = 'none';
            if (input) { input.disabled = true; input.value = 0; }
        };
        off(stockDiv, stockInput);
        off(locDiv, locInput);

        if (!motor) return;   // non-motors never carry TC

        const clampInto = function (input, floor, ceil, help, helpText) {
            let v = parseInt(input.value, 10); if (isNaN(v)) v = 0;
            v = Math.max(floor, Math.min(ceil, v));
            input.value = v;
            input.min = floor;
            input.max = ceil;
            if (help) help.textContent = floor > 0
                ? (helpText + ' (at least ' + floor + ' must be)')
                : helpText;
        };

        if (action === 'Add') {
            // Of the amount being added, any number can be TC (0..qty added).
            const qty = parseInt((document.getElementById('stock-qty-input') || {}).value, 10) || 0;
            stockDiv.style.display = 'block';
            stockInput.disabled = false;
            clampInto(stockInput, 0, Math.max(0, qty), stockHelp, 'How many added are thermocoupled?');
        } else if (action === 'Scrap') {
            const v = getSelectedVariant(item);
            const scrapQty = parseInt((document.getElementById('stock-qty-input') || {}).value, 10) || 0;
            const tcHave = v ? (v.tcqty || 0) : 0;
            const nonTc = v ? Math.max(0, (v.qty || 0) - tcHave) : 0;
            const eff = Math.min(scrapQty, v ? (v.qty || 0) : scrapQty);
            const floor = Math.max(0, eff - nonTc);      // forced TC if not enough non-TC to cover
            const ceil = Math.min(eff, tcHave);
            stockDiv.style.display = 'block';
            stockInput.disabled = false;
            clampInto(stockInput, floor, Math.max(floor, ceil), stockHelp, 'How many scrapped are thermocoupled?');
        } else if (action === 'Location Transfer') {
            const v = getSelectedVariant(item);
            const moveQty = parseInt((document.getElementById('loc-moveqty') || {}).value, 10) || 0;
            const tcHave = v ? (v.tcqty || 0) : 0;
            const nonTc = v ? Math.max(0, (v.qty || 0) - tcHave) : 0;
            const eff = Math.min(moveQty, v ? (v.qty || 0) : moveQty);
            const floor = Math.max(0, eff - nonTc);
            const ceil = Math.min(eff, tcHave);
            locDiv.style.display = 'block';
            locInput.disabled = false;
            clampInto(locInput, floor, Math.max(floor, ceil), locHelp, 'How many moved are TC?');
        }
    }

    // Recompute TC caps live as the driving quantities change.
    (function bindTcRecompute() {
        const q = document.getElementById('stock-qty-input');
        if (q) q.addEventListener('input', function () {
            const a = document.getElementById('stock-action-type').value;
            if (a === 'Add' || a === 'Scrap') refreshTcFields(a);
        });
        const mq = document.getElementById('loc-moveqty');
        if (mq) mq.addEventListener('input', function () {
            if (document.getElementById('stock-action-type').value === 'Location Transfer')
                refreshTcFields('Location Transfer');
        });
    })();

    // Variant choice changes reshape the panel: re-seed transfer source,
    // re-prefill move qty, re-check merges, or reveal the new-location cascade.
    (function bindVariantSel() {
        const sel = document.getElementById('stock-variant-sel');
        if (!sel) return;
        sel.addEventListener('change', function () {
            const action = document.getElementById('stock-action-type').value;
            if (typeof refreshTcFields === 'function') refreshTcFields(action);
            if (action === 'Location Transfer') {
                if (typeof seedLocationTransfer === 'function') seedLocationTransfer();
                refreshMoveQty();
                refreshMergeNote();
                if (typeof refreshTcFields === 'function') refreshTcFields(action);
            } else if (action === 'Add') {
                // Only the loc-div visibility depends on NEW vs existing.
                const locDiv = document.getElementById('stock-loc-div');
                const addingNew = (sel.value === 'NEW');
                if (locDiv) locDiv.style.display = addingNew ? 'block' : 'none';
                const helpText = document.getElementById('stock-qty-help');
                if (helpText) helpText.innerText = addingNew
                    ? "Amount to place at the NEW location."
                    : "Amount to ADD to current inventory.";
                if (addingNew) { locSetEnabled(true); locRefreshFda(); }
            }
        });
    })();

    /* ---- LOCATION TRANSFER cascade ----------------------------------------
       Item-first: fields seed from the selected item's stored location, then
       can be edited. Major/Sub options come from the REAL coded hierarchy
       (locHierarchyData = Parent -> Major -> [Subs]). 0 = "unspecified" and is
       selectable at every level below Parent; setting a level to 0 leaves the
       levels under it with only their 0 option (they pin to 0 naturally,
       because the hierarchy has no children under a 0 segment). */
    const locHierarchyData = @Html.Raw(locHierarchyJson);

    // Code -> friendly name for DISPLAY in the map drill. Storage/filtering stay
    // on the code; this only changes what the label reads. Unknown codes (and
    // already-friendly values) pass through unchanged.
    const locDecodeMap = @Html.Raw(locDecodeJson);
    function locDecode(code) {
        return (code != null && locDecodeMap && locDecodeMap[code]) ? locDecodeMap[code] : code;
    }

    // Populate a <select> with a leading "0 (Unspecified)", the given values,
    // and the item's current value if it isn't already present, then preselect
    // `current` (or 0 when current is blank/0).
    function locFill(selectEl, values, current) {
        if (!selectEl) return;
        const seen = {};
        const opts = [{ v: "0", label: "0 (Unspecified)" }];
        seen["0"] = true;
        (values || []).forEach(function (v) {
            if (v == null) return;
            const s = String(v).trim();
            if (!s || seen[s]) return;
            seen[s] = true;
            opts.push({ v: s, label: s });
        });
        const cur = (current == null ? "" : String(current).trim());
        if (cur && cur !== "0" && !seen[cur]) {
            seen[cur] = true;
            opts.push({ v: cur, label: cur });
        }
        selectEl.innerHTML = '';
        opts.forEach(function (o) {
            const opt = document.createElement('option');
            opt.value = o.v;
            opt.textContent = o.label;
            selectEl.appendChild(opt);
        });
        selectEl.value = (cur && cur !== "") ? cur : "0";
        if (!selectEl.value) selectEl.value = "0";
    }

    function locMajorsFor(parentCode) {
        const p = locHierarchyData[parentCode];
        return p ? Object.keys(p) : [];
    }
    function locSubsFor(parentCode, majorCode) {
        const p = locHierarchyData[parentCode];
        if (!p) return [];
        return p[majorCode] || [];
    }

    // Rebuild the FDA preview from the five fields. Blank segment -> "0".
    function locRefreshFda() {
        const seg = function (id) {
            const el = document.getElementById(id);
            const v = el ? String(el.value || '').trim() : '';
            return v === '' ? '0' : v;
        };
        const fda = [seg('loc-parent'), seg('loc-major'), seg('loc-sub'), seg('loc-rack'), seg('loc-row')].join('.');
        const out = document.getElementById('loc-fda');
        if (out) out.value = fda;
    }

    function locSetEnabled(on) {
        ['loc-parent', 'loc-major', 'loc-sub', 'loc-rack', 'loc-row'].forEach(function (id) {
            const el = document.getElementById(id);
            if (el) el.disabled = !on;
        });
        const warn = document.getElementById('loc-needs-item');
        if (warn) warn.style.display = on ? 'none' : 'block';
    }

    // Seed the cascade from the currently-selected item's stored location.
    function seedLocationTransfer() {
        const idEl = document.getElementById('stock-item-id');
        const itemId = idEl ? idEl.value : '';
        const cur = document.getElementById('loc-current');

        if (!itemId) {
            locSetEnabled(false);
            if (cur) cur.textContent = '--';
            locRefreshFda();
            return;
        }
        const item = itemsList.find(function (i) { return i.id === itemId; });
        if (!item) { locSetEnabled(false); if (cur) cur.textContent = '--'; return; }

        // Seed from the SELECTED variant (transfer source), not the item-level
        // primary -- for single-location items these are the same thing.
        const srcVar = getSelectedVariant(item) || item;

        locSetEnabled(true);
        if (cur) cur.textContent = srcVar.fda || item.fda || '--';

        // Parent (fixed coded select). Add the stored code if it isn't a known
        // option so we never silently drop a real value.
        const parentEl = document.getElementById('loc-parent');
        const pcode = (srcVar.parent == null ? '' : String(srcVar.parent).trim());
        if (parentEl) {
            const has = Array.from(parentEl.options).some(function (o) { return o.value === pcode; });
            if (pcode && !has) {
                const opt = document.createElement('option');
                opt.value = pcode; opt.textContent = pcode;
                parentEl.appendChild(opt);
            }
            parentEl.value = pcode || '';
        }

        const majorEl = document.getElementById('loc-major');
        locFill(majorEl, locMajorsFor(pcode), srcVar.major);
        const subEl = document.getElementById('loc-sub');
        locFill(subEl, locSubsFor(pcode, majorEl ? majorEl.value : ''), srcVar.sub);

        const rk = document.getElementById('loc-rack');
        const rw = document.getElementById('loc-row');
        if (rk) rk.value = (srcVar.rack == null || String(srcVar.rack).trim() === '') ? '0' : String(srcVar.rack).trim();
        if (rw) rw.value = (srcVar.row == null || String(srcVar.row).trim() === '') ? '0' : String(srcVar.row).trim();

        locRefreshFda();
        refreshMergeNote();
    }

    // Wire the cascade once on load. Bind-time does no data reads (safe re: const TDZ).
    (function bindLocTransfer() {
        const parentEl = document.getElementById('loc-parent');
        const majorEl = document.getElementById('loc-major');
        const subEl = document.getElementById('loc-sub');
        const rackEl = document.getElementById('loc-rack');
        const rowEl = document.getElementById('loc-row');

        function fdaAndMerge() { locRefreshFda(); if (typeof refreshMergeNote === 'function') refreshMergeNote(); }
        if (parentEl) parentEl.addEventListener('change', function () {
            locFill(majorEl, locMajorsFor(parentEl.value), null);
            locFill(subEl, locSubsFor(parentEl.value, majorEl ? majorEl.value : ''), null);
            fdaAndMerge();
        });
        if (majorEl) majorEl.addEventListener('change', function () {
            locFill(subEl, locSubsFor(parentEl ? parentEl.value : '', majorEl.value), null);
            fdaAndMerge();
        });
        if (subEl) subEl.addEventListener('change', fdaAndMerge);
        if (rackEl) rackEl.addEventListener('input', fdaAndMerge);
        if (rowEl) rowEl.addEventListener('input', fdaAndMerge);
    })();

    function syncHeaderOffset() {
        const header = document.querySelector('header');
        if (!header) return;
        const rect = header.getBoundingClientRect();
        const breathingRoom = 28; //accounts for the navbar's mb-3 margin + looks better kinda
        document.documentElement.style.setProperty('--vis-header-bottom' ,(rect.bottom + breathingRoom) + 'px')
    }

    if (window.location.protocol === "http:") {
        document.getElementById("http-warning").style.display = "block";
    }

    // Order Mode is "active" once the cart holds at least one item.
    let orderActive = @(hasDraft ? "true" : "false");
    let pendingAddForm = null;

    function performAdd(form) {
        fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                orderActive = true;
                document.querySelector('.rheem-navbar')?.classList.add('order-mode');
                if (window.showToast) showToast(data.message, "success");
                const b = form.querySelector('button');
                if (b) { b.classList.replace('btn-primary', 'btn-success'); b.innerText = "Added!"; b.disabled = true; }
            }
        }).catch(err => console.error(err));
    }

    document.addEventListener('submit', function (e) {
        if (e.target && typeof e.target.action === 'string' && e.target.action.includes('AddToCart')) {
            e.preventDefault();
            const form = e.target;

            // What happens once the Add to Cart modal is out of the way: the first
            // item asks to start an order (themed modal); later items just add.
            const proceed = function () {
                if (!orderActive) {
                    pendingAddForm = form;
                    const el = document.getElementById('startOrderModal');
                    if (el) { new bootstrap.Modal(el).show(); }
                    else { performAdd(form); } // fallback if modal missing
                } else {
                    performAdd(form);
                }
            };

            // Close the Add to Cart modal FIRST so it never blocks the start-order
            // modal or lingers after the add. Wait for it to fully hide (backdrop
            // gone) before the next step -- two modals never overlap (z-index safe).
            const atc = document.getElementById('addToCartModal');
            const inst = atc ? bootstrap.Modal.getInstance(atc) : null;
            if (inst) {
                atc.addEventListener('hidden.bs.modal', proceed, { once: true });
                inst.hide();
            } else {
                proceed();
            }
        }
    });

    // "Continue" on the themed start-order modal fires the stashed add.
    (function () {
        const btn = document.getElementById('startOrderConfirmBtn');
        if (btn) {
            btn.addEventListener('click', function () {
                const el = document.getElementById('startOrderModal');
                const m = el ? bootstrap.Modal.getInstance(el) : null;
                if (m) m.hide();
                if (pendingAddForm) { performAdd(pendingAddForm); pendingAddForm = null; }
            });
        }
    })();

    const zoneDataMap = @Html.Raw(mapDataJson);

    // Pre-determined coordinate path (as percentages of image width/height) for the tracking dot
    const trackingPath = [
        { x: 0.15, y: 0.45 }, // External Yard road
        { x: 0.35, y: 0.45 }, // Heading east toward building
        { x: 0.38, y: 0.75 }, // Driveway/parking lot access road
        { x: 0.55, y: 0.75 }, // Loading dock access
        { x: 0.70, y: 0.75 }, // Approaching RD Lab
        { x: 0.70, y: 0.90 }, // South loop
        { x: 0.90, y: 0.90 }, // East perimeter
        { x: 0.90, y: 0.40 }, // North perimeter
        { x: 0.65, y: 0.40 }  // Approaching New Test Cells
    ];
    let currentPathIndex = 0;

    function moveTrackingDot() {
        const img = document.getElementById('facility-map-img');
        const container = document.querySelector('.map-image-frame');
        const dot = document.getElementById('map-tracking-dot');
        if (!img || !container || !dot) return;

        // Dynamic coordinate math that recalculates with letterbox/pillarbox offsets
        const imgRect = img.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        const offsetX = imgRect.left - containerRect.left;
        const offsetY = imgRect.top - containerRect.top;

        const point = trackingPath[currentPathIndex];

        // Translates responsive percentages back into actual on-screen viewport pixels
        const posX = (point.x * img.clientWidth) + offsetX;
        const posY = (point.y * img.clientHeight) + offsetY;

        dot.style.left = posX + 'px';
        dot.style.top = posY + 'px';

        currentPathIndex = (currentPathIndex + 1) % trackingPath.length;
    }

    function resizeMap() {
        const img = document.getElementById('facility-map-img');
        const map = document.getElementById('labmap');
        const container = document.querySelector('.map-image-frame');
        if (!img || !map || !container) return;

        const originalWidth = img.naturalWidth;
        const originalHeight = img.naturalHeight;
        if (originalWidth === 0) return;

        const currentWidth = img.clientWidth;
        const currentHeight = img.clientHeight;
        const widthRatio = currentWidth / originalWidth;
        const heightRatio = currentHeight / originalHeight;

        // Gets exact starting pixel offset of the visible map image inside the black frame
        const imgRect = img.getBoundingClientRect();
        const containerRect = container.getBoundingClientRect();
        const offsetX = imgRect.left - containerRect.left;
        const offsetY = imgRect.top - containerRect.top;

        // Coordinates are measured against the natural image (1146x643), so the
        // letterbox offset + scale ratio fully position each zone. No fudge needed.
        const shiftX = 0;

        document.querySelectorAll('.map-zone').forEach(b => b.remove());

        const areas = map.getElementsByTagName('area');

        for (let a of areas) {
            if (!a.dataset.orig) a.dataset.orig = a.coords;
            const origCoords = a.dataset.orig.split(',').map(Number);
            const scaledCoords = origCoords.map((c, i) => Math.round(c * (i % 2 === 0 ? widthRatio : heightRatio)));
            a.coords = scaledCoords.join(',');

            if (scaledCoords.length === 4) {
                const x1 = scaledCoords[0];
                const y1 = scaledCoords[1];
                const w = scaledCoords[2] - x1;
                const h = scaledCoords[3] - y1;
                const title = a.title;
                const data = zoneDataMap[title];

                const centerX = x1 + (w / 2);
                const centerY = y1 + (h / 2);

                let vClass = (centerY > currentHeight * 0.6) ? 'menu-up' : 'menu-down';
                let hClass = 'menu-center';
                if (centerX < currentWidth * 0.3) hClass = 'menu-right';
                else if (centerX > currentWidth * 0.7) hClass = 'menu-left';

                const zoneDiv = document.createElement('div');
                zoneDiv.className = 'map-zone';

                // Position relative to the rendered image: scaled coord + letterbox offset
                zoneDiv.style.left = (x1 + offsetX + shiftX) + 'px';
                zoneDiv.style.top = (y1 + offsetY) + 'px';
                zoneDiv.style.width = w + 'px';
                zoneDiv.style.height = h + 'px';

                if (data && data.TotalRows > 0) {
                    let pulseClass = data.HasAlert ? 'alert-pulse' : '';
                    if (data.HasAlert) zoneDiv.classList.add('alert-zone');
                    let warningIcon = data.HasAlert ? `<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark" style="font-size:10px; padding:4px;"><i class="bi bi-exclamation-triangle-fill"></i></span>` : '';

                    let innerHTML = `
                        <div class="zone-marker ${pulseClass}" title="${title}" style="position:relative;">
                            <i class="bi bi-geo-alt-fill marker-icon"></i>
                            <span class="marker-count">${data.TotalRows} Rows</span>
                            ${warningIcon}
                        </div>
                    `;

                    innerHTML += `
                        <div class="zone-menu ${vClass} ${hClass}">
                            <div class="zone-menu-header">${title} Locations</div>
                            <button type="button" class="zone-menu-btn" onclick="window.location.href='${a.href}'">
                                <span><i class="bi bi-globe me-2"></i>View All</span>
                                <span class="badge bg-secondary">${data.TotalRows}</span>
                            </button>
                    `;

                    for (let major in data.Majors) {
                        let mData = data.Majors[major];
                        let mAlert = mData.HasAlert ? `<i class="bi bi-exclamation-triangle-fill text-warning ms-2"></i>` : ``;
                        let majorLink = `/Home/Index?mode=Filter&filterNotes=${encodeURIComponent(major)}`;
                        let subKeys = mData.Subs ? Object.keys(mData.Subs) : [];

                        if (subKeys.length > 0) {
                            // Major has real sub-areas -> expandable group (Parent > Major > Sub).
                            let subsHTML = `
                                <button type="button" class="zone-menu-btn zone-subbtn" onclick="window.location.href='${majorLink}'">
                                    <span><i class="bi bi-grid-3x3-gap me-2"></i>View all ${locDecode(major)}</span>
                                    <span class="badge bg-secondary">${mData.Rows}</span>
                                </button>`;
                            for (let sub in mData.Subs) {
                                let sData = mData.Subs[sub];
                                let sAlert = sData.HasAlert ? `<i class="bi bi-exclamation-triangle-fill text-warning ms-2"></i>` : ``;
                                subsHTML += `
                                    <button type="button" class="zone-menu-btn zone-subbtn" onclick="window.location.href='/Home/Index?mode=Filter&filterNotes=${encodeURIComponent(sub)}'">
                                        <span><i class="bi bi-box me-2"></i>${locDecode(sub)} ${sAlert}</span>
                                        <span class="badge bg-secondary">${sData.Rows}</span>
                                    </button>`;
                            }

                            innerHTML += `
                                <div class="zone-major-group">
                                    <button type="button" class="zone-menu-btn zone-major-toggle"
                                            onclick="event.stopPropagation(); this.closest('.zone-major-group').classList.toggle('open');">
                                        <span><i class="bi bi-diagram-3 me-2"></i>${locDecode(major)} ${mAlert}</span>
                                        <span class="badge bg-secondary">${mData.Rows}<i class="bi bi-chevron-down zone-chev"></i></span>
                                    </button>
                                    <div class="zone-submenu">${subsHTML}</div>
                                </div>`;
                        } else {
                            // No real sub-areas -> single button straight to the filter.
                            innerHTML += `
                                <button type="button" class="zone-menu-btn" onclick="window.location.href='${majorLink}'">
                                    <span><i class="bi bi-box-seam me-2"></i>${locDecode(major)} ${mAlert}</span>
                                    <span class="badge bg-secondary">${mData.Rows}</span>
                                </button>`;
                        }
                    }
                    innerHTML += `</div>`;
                    zoneDiv.innerHTML = innerHTML;

                    zoneDiv.onclick = (e) => {
                        e.stopPropagation();

                        const menu = zoneDiv.querySelector('.zone-menu');
                        const isShowing = menu.classList.contains('show');

                        // Close other active menus and lower their stack heights
                        document.querySelectorAll('.zone-menu.show').forEach(m => m.classList.remove('show'));
                        document.querySelectorAll('.map-zone.active-zone').forEach(z => z.classList.remove('active-zone'));

                        if (!isShowing) {
                            menu.classList.add('show');
                            zoneDiv.classList.add('active-zone'); // Elevate active popup z-index above all other pins
                        }
                    };
                } else {
                    zoneDiv.title = `${title} (Empty)`;
                    zoneDiv.onclick = () => window.location.href = a.href;
                }

                container.appendChild(zoneDiv);
            }
        }

        // Refresh tracker dot position instantly during map container resizing
        moveTrackingDot();
    }

    document.addEventListener('click', () => {
        document.querySelectorAll('.zone-menu.show').forEach(m => m.classList.remove('show'));
        document.querySelectorAll('.map-zone.active-zone').forEach(z => z.classList.remove('active-zone'));
    });

    window.addEventListener('load', () => {
        resizeMap();
        // Cycle the tracking dot coordinates smoothly on a 2.5-second loop
        setInterval(moveTrackingDot, 2500);
    });

    window.addEventListener('resize', resizeMap);
    const facilityImg = document.getElementById('facility-map-img');
    if(facilityImg) facilityImg.addEventListener('load', resizeMap);

    window.addEventListener('load', syncHeaderOffset);
    window.addEventListener('resize', syncHeaderOffset);
    syncHeaderOffset();

    document.addEventListener('click', function (e) {
        const row = e.target.closest('.holo-row');
        if (!row) return;
        document.querySelectorAll('.holo-row').forEach(r => r.classList.remove('selected'));
        row.classList.add('selected');
        const b = document.getElementById('holo-add-submit');
        const i = document.getElementById('holo-add-itemId');
        if (b && i) { b.disabled = false; i.value = row.dataset.itemId; }
    });

    const itemsList = @Html.Raw(ViewBag.AutocompleteJson ?? "[]");

    function bindAutocomplete(inputId, listId, idOutputId, isAlertModal) {
        const searchInput = document.getElementById(inputId);
        const autoList = document.getElementById(listId);
        const idInput = document.getElementById(idOutputId);

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                let val = this.value.toLowerCase();
                autoList.innerHTML = '';
                if (!val) { autoList.style.display = 'none'; return; }

                let matches = itemsList.filter(i =>
                    i.id.toLowerCase().includes(val) || i.name.toLowerCase().includes(val)
                ).slice(0, 10);

                if (matches.length > 0) {
                    autoList.style.display = 'block';
                    matches.forEach(m => {
                        let btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action py-2 px-3 small border-bottom border-dark text-white';
                        btn.style.backgroundColor = '#1C1E24';
                        btn.innerHTML = `<strong class="text-primary">${m.id}</strong> - ${m.name} <span class="text-light-gray float-end">Qty: ${m.quantity}</span>`;

                        btn.onclick = function() {
                            searchInput.value = m.name;
                            idInput.value = m.id;
                            autoList.style.display = 'none';

                            if (isAlertModal) {
                                document.getElementById('alert-threshold').value = m.threshold;
                            } else if (typeof toggleStockUI === 'function') {
                                // Rebuild the variant selector + re-seed the cascade
                                // for the newly picked item, whatever the action.
                                toggleStockUI();
                            }
                        };

                        btn.onmouseover = () => btn.style.backgroundColor = '#2A2D35';
                        btn.onmouseout = () => btn.style.backgroundColor = '#1C1E24';

                        autoList.appendChild(btn);
                    });
                } else {
                    autoList.style.display = 'none';
                }
            });

            document.addEventListener('click', function(e) {
                if (e.target !== searchInput) autoList.style.display = 'none';
            });
        }
    }

    bindAutocomplete('alert-search', 'alert-autocomplete-list', 'alert-item-id', true);
    bindAutocomplete('stock-search', 'stock-autocomplete-list', 'stock-item-id', false);

    (function() {
        const historyChks = document.querySelectorAll('.exp-history-chk');
        const timeFrameDiv = document.getElementById('expTimeFrameDiv');
        if (historyChks && timeFrameDiv) {
            historyChks.forEach(chk => {
                chk.addEventListener('change', () => {
                    timeFrameDiv.style.display = Array.from(historyChks).some(c => c.checked) ? 'block' : 'none';
                });
            });
        }

        const teamSel = document.getElementById('reg-team');
        const codeInput = document.getElementById('reg-projcode');
        if (teamSel && codeInput) {
            teamSel.addEventListener('change', function() {
                codeInput.value = this.options[this.selectedIndex].getAttribute('data-code');
            });
        }

        // ---- Live Item ID preview -----------------------------------------
        // Shows the predicted ID (<GroupInitial><Type first+last>-NNNN) as the
        // user picks Group / types Type. The number is read from the items
        // already on the page. This is ONLY a preview: HomeController.CreateItem
        // recomputes and assigns the real ID at save, so a stale number here
        // can never cause a clash. The success toast shows the actual ID.
        const regGroup = document.getElementById('reg-group');
        const regType = document.getElementById('reg-type');
        const regIdOut = document.getElementById('reg-itemid');

        function regBuildPrefix() {
            let g = (regGroup && regGroup.value ? regGroup.value : 'Commercial').trim();
            let t = (regType && regType.value ? regType.value : '').trim();
            if (g === '') g = 'Commercial';
            if (t === '') t = 'General';
            const gi = g.charAt(0).toUpperCase();
            const tc = (t.charAt(0) + t.charAt(t.length - 1)).toUpperCase();
            return gi + tc + '-';
        }
        function regPreviewId() {
            if (!regIdOut) return;
            const prefix = regBuildPrefix();
            let max = 0;
            const list = (typeof itemsList !== 'undefined' && itemsList) ? itemsList : [];
            list.forEach(function (it) {
                const id = (it && it.id) ? String(it.id) : '';
                if (id.indexOf(prefix) === 0) {
                    const numPart = id.substring(prefix.length);
                    if (/^\d+$/.test(numPart)) {
                        const n = parseInt(numPart, 10);
                        if (n > max) max = n;
                    }
                }
            });
            regIdOut.value = prefix + String(max + 1).padStart(4, '0');
        }
        if (regGroup) regGroup.addEventListener('change', regPreviewId);
        if (regType) regType.addEventListener('input', regPreviewId);
        // Refresh the preview each time the registry modal opens.
        const newItemModal = document.getElementById('newItemModal');
        if (newItemModal) newItemModal.addEventListener('shown.bs.modal', regPreviewId);

        // Location hierarchy (friendly names only). Codes are derived by the
        // SAME rule the server uses (Services/LocationCodec) via encodeLoc(),
        // so the live preview always matches what actually gets saved.
        const locMap = {
            "RD Lab": { "Metrology Mezzanine": ["Samurai", "Ninja"], "2-6": [] },
            "External Yard": { "Connex Area": ["Connex Box 6"], "Trailer Area": ["Trailer 1"] },
            "New Test Cells": {},
            "Plant Test Cells": {}
        };

        // Mirror of LocationCodec.Encode: 1st, 3rd, 5th and last letter/digit
        // of the cleaned name, de-duplicated, kept in ascending order.
        function encodeLoc(name) {
            if (!name) return "";
            const clean = name.toUpperCase().replace(/[^A-Z0-9]/g, "");
            if (!clean.length) return "";
            const n = clean.length;
            const pos = [...new Set([1, 3, 5, n].filter(p => p >= 1 && p <= n))].sort((a, b) => a - b);
            return pos.map(p => clean[p - 1]).join("");
        }

        function bindCascadingLocation(pId, mId, sId, rkId, rwId, fdaId) {
            const pSel = document.getElementById(pId);
            const mSel = document.getElementById(mId);
            const sSel = document.getElementById(sId);
            const rkIn = document.getElementById(rkId);
            const rwIn = document.getElementById(rwId);
            const fdaOut = document.getElementById(fdaId);

            function updateFda() {
                if(!pSel || !fdaOut) return;

                let pCode = encodeLoc(pSel.value);
                let mCode = encodeLoc(mSel.value);
                let sCode = encodeLoc(sSel.value);

                let rkCode = rkIn ? rkIn.value.trim().toUpperCase() : "";
                let rwCode = rwIn ? rwIn.value.trim() : "";

                let parts = [pCode, mCode, sCode, rkCode, rwCode].filter(x => x !== "");
                fdaOut.value = parts.join('.');
            }

            if (pSel) {
                pSel.addEventListener('change', function() {
                    mSel.innerHTML = '<option value="">Select Major...</option>';
                    sSel.innerHTML = '<option value="">Select Sub...</option>';
                    sSel.disabled = true;

                    let pName = this.value;
                    let majors = (pName && locMap[pName]) ? Object.keys(locMap[pName]) : [];
                    if (majors.length > 0) {
                        mSel.disabled = false;
                        majors.forEach(m => mSel.add(new Option(m, m)));
                    } else {
                        mSel.disabled = true;
                    }
                    updateFda();
                });

                mSel.addEventListener('change', function() {
                    sSel.innerHTML = '<option value="">Select Sub...</option>';
                    let pName = pSel.value;
                    let mName = this.value;
                    let subs = (pName && mName && locMap[pName] && locMap[pName][mName]) ? locMap[pName][mName] : [];

                    if (subs.length > 0) {
                        sSel.disabled = false;
                        subs.forEach(s => sSel.add(new Option(s, s)));
                    } else {
                        sSel.disabled = true;
                    }
                    updateFda();
                });

                sSel.addEventListener('change', updateFda);
                if(rkIn) rkIn.addEventListener('input', updateFda);
                if(rwIn) rwIn.addEventListener('input', updateFda);
            }
        }

        bindCascadingLocation('reg-parent', 'reg-major', 'reg-sub', 'reg-rack', 'reg-row', 'reg-fda');
        bindCascadingLocation('exp-parent', 'exp-major', 'exp-sub', null, null, 'exp-fda');
    })();
    function updateLiveTrackingTime() {
        const now = new Date();
        let hours = now.getHours();
        const minutes = String(now.getMinutes()).padStart(2, '0');
        const seconds = String(now.getSeconds()).padStart(2, '0');
        const ampm = hours >= 12 ? 'PM' : 'AM';

        hours = hours % 12;
        hours = hours ? hours : 12; // Formats '0' to '12'

        const strTime = `${hours}:${minutes}:${seconds} ${ampm}`;
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const year = now.getFullYear();

        const formattedText = `${strTime} ${month}/${day}/${year}`;

        // Locates the span in the live tracking bar and updates the text
        const timeSpan = document.getElementById('last-updated-time');
        if (timeSpan) {
            timeSpan.innerText = formattedText;
        }
    }

    // Call on load alongside your map resizer
    window.addEventListener('load', () => {
        updateLiveTrackingTime();
    });
</script>